{
  "name": "pourhouse",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "dev:full": "npm run db:up && npm run dev",
    "build": "tsc && tsc-alias",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "start": "node dist/server.js",
    "square:fetch": "tsx -r tsconfig-paths/register scripts/fetchSquareCatalog.ts",
    "square:seed:sandbox": "tsx -r tsconfig-paths/register scripts/seedSquareSandboxCatalog.ts",
    "square:sync:wines": "tsx -r tsconfig-paths/register scripts/syncSquareCatalogToWines.ts",
    "seed:sample:data": "tsx -r tsconfig-paths/register scripts/seedSampleData.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose stop postgres",
    "db:status": "docker compose ps",
    "db:logs": "docker compose logs -f postgres",
    "db:reset": "docker compose down -v",
    "db:setup": "npm run db:up && npm run prisma:migrate && npm run prisma:seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/client": "6.16.2",
    "bcrypt": "6.0.0",
    "cors": "2.8.6",
    "dotenv": "17.3.1",
    "express": "5.2.1",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.3",
    "morgan": "1.10.1",
    "square": "44.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bcrypt": "6.0.0",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/morgan": "1.9.10",
    "@types/node": "25.5.0",
    "@types/supertest": "7.2.0",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "@vitest/coverage-v8": "4.1.0",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "prisma": "6.16.2",
    "supertest": "7.2.2",
    "ts-node-dev": "2.0.0",
    "tsc-alias": "1.8.16",
    "tsconfig-paths": "4.2.0",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "4.1.0",
    "xlsx": "0.18.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
